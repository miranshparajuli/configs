{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "none"
  },
  "display": {
    "separator": ": "

  },
  "modules": [
    "os",
    {
        "type": "wm",
        "format": "{1}"
    },
    {
        "type": "shell",
        "format": "{1}"
    },
    "uptime",
    {
        "type":"memory",
        "format": "{1} / {2}"
    }
  ]
}
